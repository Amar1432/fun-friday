# Dependency / build caches
node_modules
**/node_modules
.pnpm-store
dist
**/dist
.next
coverage

# Env & secrets — never bake into the image
.env
.env.*
!.env.example

# Local / VCS / editor
.git
.gitignore
.github
.vscode
.idea
.DS_Store

# Test & docs (not needed at runtime)
**/*.spec.ts
**/*.test.ts
**/*.e2e-spec.ts
test
docs
*.md
