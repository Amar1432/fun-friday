# Runtime mode. Allowed values: development, test, production.
NODE_ENV=development

# Port used by the NestJS HTTP and Socket.IO server.
# Format: integer from 1 to 65535.
PORT=3001

# PostgreSQL connection used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL=postgresql://amarjeet:1432@localhost:5432/fun_friday?schema=public

# Redis connection used for ephemeral room and game state.
# Format: redis://[:PASSWORD@]HOST:PORT[/DATABASE]
REDIS_URL=redis://localhost:6379/0

# Private key used to sign host and guest JWTs. Generate a random value of at
# least 32 bytes for each environment; never use this example in production.
JWT_SECRET=replace-with-at-least-32-random-bytes

# Expiration duration for signed JWTs (e.g., 24h, 7d).
JWT_EXPIRATION=24h

# Google OAuth 2.0 Client ID for SSO login.
# Obtain from the Google Cloud Console → APIs & Services → Credentials.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Microsoft OAuth 2.0 Client ID for SSO login.
# Obtain from Microsoft Entra ID (Azure Portal) App Registrations.
MICROSOFT_CLIENT_ID=your-microsoft-client-id-uuid

# Browser origin allowed to call the API with credentials.
# Format: absolute HTTP(S) origin without a trailing slash.
FRONTEND_ORIGIN=http://localhost:3000
