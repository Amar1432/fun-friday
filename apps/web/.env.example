# Public base URL of the REST API. Must be an absolute HTTP(S) URL and include
# the versioned API path. NEXT_PUBLIC_ values are exposed to browser code.
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Public URL that receives the host after authentication completes.
# Format: absolute HTTP(S) URL.
NEXT_PUBLIC_AUTH_CALLBACK_URL=http://localhost:3000/auth/callback

# Product name displayed in the frontend.
NEXT_PUBLIC_APP_NAME=Fun Friday Hub

# Google OAuth 2.0 Client ID (same value as in the API .env).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Microsoft OAuth 2.0 Client ID (same value as in the API .env).
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=your-microsoft-client-id-uuid

